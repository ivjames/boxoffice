# Copy to .env and fill in for your environment. Never commit the real .env.

# django.core.management.utils.get_random_secret_key() to generate one.
SECRET_KEY=change-me-to-a-long-random-string

# "true" / "false". Must be false in production.
DEBUG=true

# Comma-separated. e.g. boxoffice.lab980.com,.lab980.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres in prod, e.g.:
#   postgres://boxoffice:password@localhost:5432/boxoffice
# Dev settings fall back to a local SQLite file if this is unset, so DATABASE_URL
# is optional for local development. It is REQUIRED in prod (config/settings/prod.py
# raises if it's missing).
DATABASE_URL=

# Reserved subdomains that map to the platform host (marketing/landing, signup,
# Django admin) instead of a tenant. Comma-separated, no dots.
RESERVED_SUBDOMAINS=www,app,admin

# The base domain tenants live under, e.g. lab980.com -> theater.lab980.com.
# Used by TenantMiddleware to strip the base domain off the Host header.
BASE_DOMAIN=localhost
