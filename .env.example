# Copy to .env and fill in for your environment. Never commit the real .env.
# .env lives at the repo root (BASE_DIR), next to manage.py -- config.settings.base
# reads it via django-environ. Prod (lab980 droplet) seeds this file's PORT via
# `provision-site`; everything else here you set by hand once per site.

# --- Core Django ---------------------------------------------------------

# REQUIRED in prod (config/settings/prod.py has no insecure fallback there).
# Generate a SHELL-SAFE key (alphanumeric only -- Django's default key can
# contain ()$&* which need quoting when the file is read by a shell):
#   python -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(64)))"
# bin/boxoffice parses this file literally (no sourcing), so quotes are
# optional; single-quoting any value with metacharacters is still good hygiene.
SECRET_KEY='change-me-to-a-long-random-string'

# "true" / "false". Must be false in production.
DEBUG=true

# Which settings module manage.py / gunicorn load. manage.py defaults to
# config.settings.dev (zero-config local dev); prod deploys MUST set this
# explicitly -- pm2/the shell environment, not just this file, since some
# tools (e.g. gunicorn invoked by bin/boxoffice serve) read it before .env
# is parsed. bin/boxoffice exports config.settings.prod by default if unset.
DJANGO_SETTINGS_MODULE=config.settings.prod

# Comma-separated. e.g. boxo.show,.boxo.show (the bare apex is the platform
# host; the leading-dot entry covers every tenant subdomain).
# prod default (config/settings/prod.py) is ".boxo.show" if unset.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated, must include scheme. Needed because every tenant
# subdomain POSTs (checkout, dashboard forms, admin) cross-origin from
# Django's point of view. prod default is
# "https://*.boxo.show,https://boxo.show" if unset.
CSRF_TRUSTED_ORIGINS=https://*.boxo.show,https://boxo.show

# --- Login throttling -----------------------------------------------------

# Cache-backed rate limit on staff login + the guest magic-link request
# (accounts/throttle.py). After MAX_ATTEMPTS failures from one IP within
# WINDOW_SECONDS, further attempts are refused until the window rolls off.
# Defaults (10 / 900s) are sane; set MAX_ATTEMPTS=0 to disable. Prod uses a
# file-based cache shared across gunicorn workers so the limit actually holds.
LOGIN_RATELIMIT_MAX_ATTEMPTS=10
LOGIN_RATELIMIT_WINDOW_SECONDS=900

# --- Multi-tenancy --------------------------------------------------------

# Reserved subdomains that map to the platform host (marketing/landing,
# signup, Django admin) instead of a tenant. Comma-separated, no dots.
# The platform host is now the bare apex (boxo.show), so no app subdomain
# needs reserving for it. Do reserve "beta" (the staging deploy's host,
# beta.boxo.show) plus any other platform hosts (www, app, admin) so a tenant
# can't claim them:
#   RESERVED_SUBDOMAINS=www,app,admin,beta
RESERVED_SUBDOMAINS=www,app,admin,beta

# The base domain tenants live under, e.g. boxo.show -> theater.boxo.show.
# Used by TenantMiddleware to strip the base domain off the Host header, and
# by `bin/boxoffice add-tenant`/`remove-tenant` to build the tenant's FQDN
# and doctl DNS zone name.
BASE_DOMAIN=localhost

# Optional. Only set this if the doctl DNS zone name differs from
# BASE_DOMAIN (unusual) -- `bin/boxoffice add-tenant`/`remove-tenant` use
# DOMAIN for `doctl compute domain records ...` if set, else fall back to
# BASE_DOMAIN.
#DOMAIN=boxo.show

# "true" / "false". Default false. When true, the platform-host landing page
# shows a convenience "Admin" link (-> /admin/) in the nav and footer. Leave
# false on prod (the public marketing page shouldn't advertise the superuser
# surface); the staging/beta deploy sets it true. /admin/ is reachable
# directly regardless.
SHOW_ADMIN_LINK=false

# --- Database --------------------------------------------------------------

# Optional. Omit this entirely to use SQLite in the app-dir data/ directory
# (config/settings/prod.py: data/db.sqlite3) -- the lab980 one-dir-per-site
# default, zero extra infra. Set to a postgres:// URL to upgrade; nothing
# else in the app changes (see docs/DEPLOY.md "SQLite -> Postgres").
#   postgres://boxoffice:password@localhost:5432/boxoffice
DATABASE_URL=

# --- Process (gunicorn / pm2 / bin/boxoffice) ------------------------------

# Local port gunicorn binds on 127.0.0.1. Left blank here on purpose --
# lab980 `provision-site` seeds this automatically (next free port from
# 8060) when it scaffolds the site; the nginx vhost (and every tenant vhost
# added by `boxoffice add-tenant`) proxies here. `boxoffice serve` refuses
# to start without it.
PORT=

# gunicorn --workers. Rule of thumb: (2 x CPU cores) + 1. Keep modest on a
# shared droplet running many sites.
WEB_CONCURRENCY=3

# --- Email (SMTP, prod only -- dev uses the console backend) --------------

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@boxo.show

# --- TEST CHECKOUT (fake payment, NO Stripe account needed) --------------

# "true" / "false". DEFAULT/SAFE VALUE IS false. When true, a "Pay (TEST --
# no real charge)" button appears on /checkout/ and POSTing it creates a
# real Order + Tickets (and sends the ticket email) WITH NO PAYMENT OF ANY
# KIND -- no Stripe account, no Stripe keys, nothing charged, ever. It
# exists ONLY so you can exercise the full browse -> buy -> ticket -> scan
# flow before you've set up Stripe for a tenant.
#
# !!! DANGER: NEVER SET THIS TO true ON A REAL, LIVE, PUBLIC PRODUCTION SITE
# !!! -- doing so lets ANYONE who finds the checkout page mint themselves
# !!! free real tickets. Leave unset/false everywhere except a deliberate,
# !!! throwaway, or pre-launch test environment.
ENABLE_TEST_CHECKOUT=false

# --- Stripe Connect (platform account) -----------------------------------

# boxo.show is the PLATFORM Stripe account; each theater is a connected
# (Express) account it onboards. These three are set ONCE, platform-wide (not
# per tenant) -- the connected-account id lives on each Organization row and is
# created by the in-app onboarding flow, never pasted here.
#
# Test keys during development; live keys in prod. The webhook secret is for
# the single CONNECT endpoint (Dashboard -> Developers -> Webhooks -> add an
# endpoint "in your Connect application", pointed at https://<BASE_DOMAIN>/webhooks/stripe/,
# subscribed to at least `checkout.session.completed` and `account.updated`).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform take rate (applied as a Stripe application fee on each direct
# charge): percent of order total + a flat per-order amount in cents. BOTH
# DEFAULT TO 0 = no cut -- the fee mechanism is live but charges nothing until
# a rate is chosen. A single theater can be overridden from /admin
# (Organization.platform_fee_percent) without touching this.
PLATFORM_FEE_PERCENT=0
PLATFORM_FEE_FIXED_CENTS=0
